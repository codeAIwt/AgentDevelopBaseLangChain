# 应用配置
APP_NAME=AgentDevelopBase
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 数据库配置
DATABASE_URL=postgresql://postgre_langchain:postgreLangchain@db:5432/Agent_DB1
POSTGRES_USER=postgre_langchain
POSTGRES_PASSWORD=postgreLangchain
POSTGRES_DB=Agent_DB1
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# LangChain 配置
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=agent-develop-base

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI 配置（可选）
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# 其他 LLM 提供商配置
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=

# 安全配置
SECRET_KEY=your_secret_key_here_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
