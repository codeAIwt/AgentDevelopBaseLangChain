# Database
DATABASE_URL=postgresql://agent_user:PostgreDB@localhost:5432/Agent_DB1
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=PostgreDB
POSTGRES_DB=Agent_DB1
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Application
DEBUG=true
APP_PORT=8000
LOG_LEVEL=info

# DeepSeek Configuration (用于 LLM 调用)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE_TYPE=chroma

# Local Model (用于 Blender 建模)
MODEL_PATH=models
MODEL_FILE=models/qwen2.5-coder-3b-instruct-q5_k_m.gguf

# Checkpointer (LangChain Memory)
CHECKPOINTER_TYPE=memory  # memory | sqlite | postgres

